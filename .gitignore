# Deny-all whitelist: only explicitly allowed files are tracked.
*

# Docs
!docs/
!docs/plans/
!docs/plans/*.md

# Project root files
!.gitattributes
!.gitignore
!.gitmessage
!CLAUDE.md
!CONTRIBUTING.md
!LICENSE
!pyproject.toml
!README.md
!SKILL.md

# Git hooks
!.githooks/
!.githooks/commit-msg

# Source
!scripts/
!scripts/dyk.py
!scripts/helpers.py
!scripts/serve_hook.py
!scripts/fetch_hooks.py
!scripts/write_tags.py
!scripts/prefs.py

# Tests
!tests/
!tests/test_dyk.py
!tests/test_helpers.py
!tests/test_serve_hook.py
!tests/test_fetch_hooks.py
!tests/test_write_tags.py
!tests/test_prefs.py

# References
